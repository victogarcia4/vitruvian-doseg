# DoseGennie - Environment Variables Template
# Copy this file to .env.local and fill in your actual values

# ============================================
# DATABASE
# ============================================
# PostgreSQL/Supabase connection string
# DATABASE_URL="postgresql://user:password@host:5432/database"

# ============================================
# AUTHENTICATION
# ============================================
# NextAuth.js secret (generate with: openssl rand -base64 32)
# NEXTAUTH_SECRET=""
# NEXTAUTH_URL="http://localhost:3000"

# OAuth Providers (if using social login)
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# ============================================
# AI/LLM SERVICES
# ============================================
# OpenAI for AI-powered explanations and adaptive learning
# OPENAI_API_KEY=""

# Anthropic Claude (alternative)
# ANTHROPIC_API_KEY=""

# ============================================
# PAYMENTS (for subscription plans)
# ============================================
# Stripe for Student/Professional/Institution plans
# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# ============================================
# EMAIL SERVICE
# ============================================
# SendGrid, Resend, or similar for transactional emails
# EMAIL_SERVER_HOST=""
# EMAIL_SERVER_PORT=""
# EMAIL_SERVER_USER=""
# EMAIL_SERVER_PASSWORD=""
# EMAIL_FROM="noreply@vitruviandoseg.com"

# ============================================
# ANALYTICS & MONITORING
# ============================================
# Google Analytics
# NEXT_PUBLIC_GA_ID=""

# Vercel Analytics (automatically enabled on Vercel)
# Already included in Vercel deployments

# Sentry for error tracking
# SENTRY_DSN=""

# ============================================
# FEATURE FLAGS
# ============================================
# Enable/disable features during development
# NEXT_PUBLIC_ENABLE_BETA_FEATURES="false"
# NEXT_PUBLIC_ENABLE_MULTILINGUAL="true"

# ============================================
# DEVELOPMENT
# ============================================
# Show debug information in development
# NEXT_PUBLIC_DEBUG_MODE="false"
